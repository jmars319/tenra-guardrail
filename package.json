{
  "name": "tenra-guardrail",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first tenra safety boundary for Tool Host policy review and agent action control.",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.21.1",
    "pnpm": ">=10.32.1"
  },
  "scripts": {
    "bootstrap": "bash ./scripts/bootstrap.sh",
    "check:env": "bash ./scripts/check-env.sh",
    "check:packages": "bash ./scripts/check-packages.sh",
    "dev:web": "bash ./scripts/dev-web.sh",
    "dev:desktop": "bash ./scripts/dev-desktop.sh",
    "dev:mobile": "bash ./scripts/dev-mobile.sh",
    "dev:both": "bash ./scripts/dev-both.sh",
    "build:web": "pnpm --filter @guardrail/webapp build",
    "build:desktop": "pnpm --filter @guardrail/desktopapp build:tauri",
    "package:desktop": "pnpm run build:desktop",
    "install:desktop": "pnpm run package:desktop && bash ./scripts/install-desktop-app.sh",
    "launch:desktop": "open -n \"/Applications/tenra Guardrail.app\"",
    "build:mobile": "pnpm --filter @guardrail/mobileapp build",
    "lint": "pnpm -r --workspace-concurrency=1 run lint",
    "typecheck": "pnpm -r --workspace-concurrency=1 run typecheck",
    "verify:web": "bash ./scripts/verify-web.sh",
    "verify:desktop": "bash ./scripts/verify-desktop.sh",
    "verify:mobile": "bash ./scripts/verify-mobile.sh",
    "verify:handoffs": "node ./scripts/validate-handoffs.mjs",
    "verify:all": "bash ./scripts/verify-all.sh && pnpm run audit:maintainability && pnpm run budget:bundle",
    "doctor": "bash ./scripts/doctor.sh",
    "analyze:bundle": "node scripts/analyze-build.mjs",
    "budget:bundle": "node scripts/analyze-build.mjs --strict",
    "audit:maintainability": "node scripts/audit-maintainability.mjs --strict"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.0.3",
    "globals": "17.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0"
  }
}
